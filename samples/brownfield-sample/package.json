{
  "name": "order-management-service",
  "version": "2.4.1",
  "description": "REST API service for managing customer orders",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "aef:scan": "node scripts/aef-scan.mjs --target .",
    "aef:report": "node scripts/aef-report.mjs --assessment docs/assessment/readiness-assessment.json"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.1",
    "winston": "^3.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/acme-corp/order-management-service.git"
  },
  "keywords": [
    "orders",
    "ecommerce",
    "api",
    "rest"
  ],
  "author": "Fulfillment Engineering <fulfillment@acme-corp.com>",
  "license": "UNLICENSED",
  "private": true
}
