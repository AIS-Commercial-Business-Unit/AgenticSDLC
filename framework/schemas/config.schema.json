{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ais.com/agentic-sdlc/framework/schemas/config.schema.json",
  "title": "AIS Agentic Engineering Framework Configuration",
  "description": "JSON Schema 2020-12 for validating aispec.config.yaml. Every field mirrors the documented example config (config/aispec.config.example.yaml).",
  "type": "object",
  "required": ["framework", "repository", "specify", "governance", "work_management", "agents"],
  "additionalProperties": false,
  "$comment": "Phase 2 additions: mcp and assessment sections are optional. work_management extended with milestone_prefix, issue_type, area_path, and mock provider.",
  "properties": {
    "framework": {
      "type": "object",
      "description": "Framework identity and version metadata.",
      "required": ["version"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Framework version string (semver).",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "schema": {
          "type": "string",
          "description": "Relative path to this JSON schema file."
        },
        "initialized_at": {
          "type": ["string", "null"],
          "description": "ISO-8601 timestamp when config was first created.",
          "format": "date-time"
        },
        "initialized_by": {
          "type": "string",
          "description": "GitHub username or identity that initialized the framework."
        }
      }
    },
    "repository": {
      "type": "object",
      "description": "Target repository context.",
      "required": ["name", "owner", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Repository name."
        },
        "owner": {
          "type": "string",
          "description": "GitHub org or user owning the repo."
        },
        "type": {
          "type": "string",
          "description": "Whether the repo is brownfield (existing) or greenfield (new).",
          "enum": ["brownfield", "greenfield"]
        },
        "description": {
          "type": "string",
          "description": "One-line description of the repository's purpose."
        },
        "stack": {
          "type": "object",
          "description": "Technology stack inventory.",
          "additionalProperties": false,
          "properties": {
            "languages": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Primary programming languages."
            },
            "frameworks": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Frameworks in use."
            },
            "build_tools": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Build and package tools."
            },
            "deployment_targets": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Deployment targets (e.g., aks, azure-app-service)."
            },
            "ci_cd": {
              "type": "array",
              "items": { "type": "string" },
              "description": "CI/CD platforms in use."
            }
          }
        },
        "maturity": {
          "type": "object",
          "description": "Repository AI maturity assessment.",
          "additionalProperties": false,
          "properties": {
            "level": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4,
              "description": "Maturity level 0-4. 0=No AI tooling; 1=Ad-hoc; 2=Structured; 3=Governed; 4=Optimizing."
            },
            "assessed_at": {
              "type": ["string", "null"],
              "description": "ISO-8601 timestamp of last assessment.",
              "format": "date-time"
            },
            "assessed_by": {
              "type": "string",
              "description": "Who performed the assessment."
            }
          }
        }
      }
    },
    "specify": {
      "type": "object",
      "description": "AIS Specify SDLC lifecycle configuration.",
      "required": ["lifecycle_steps", "current_step"],
      "additionalProperties": false,
      "properties": {
        "lifecycle_steps": {
          "type": "array",
          "description": "Ordered list of active lifecycle steps.",
          "items": {
            "type": "string",
            "enum": ["Intake", "Specify", "Design", "Plan", "Implement", "Verify", "Deploy", "Report", "Learn"]
          },
          "minItems": 1
        },
        "current_step": {
          "type": "string",
          "description": "The step the team is currently executing.",
          "enum": ["Intake", "Specify", "Design", "Plan", "Implement", "Verify", "Deploy", "Report", "Learn"]
        },
        "artifact_root": {
          "type": "string",
          "description": "Root directory where Specify artifacts are stored."
        }
      }
    },
    "governance": {
      "type": "object",
      "description": "Agent autonomy, approval, and governance controls.",
      "required": ["registry", "default_autonomy_level"],
      "additionalProperties": false,
      "properties": {
        "registry": {
          "type": "string",
          "description": "Path to governance activity registry YAML."
        },
        "default_autonomy_level": {
          "type": "string",
          "description": "Default autonomy level for all agents unless overridden in the registry.",
          "enum": ["L0", "L1", "L2", "L3"]
        },
        "confidence_thresholds": {
          "type": "object",
          "description": "Minimum confidence scores for each action class.",
          "additionalProperties": false,
          "properties": {
            "recommend": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "prepare": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "execute": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "escalation": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "block": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        "hard_constraints": {
          "type": "object",
          "description": "G1 hard constraints enforced outside model reasoning.",
          "additionalProperties": false,
          "properties": {
            "protected_branches_require_approval": { "type": "boolean" },
            "secrets_cannot_be_committed": { "type": "boolean" },
            "agents_cannot_modify_own_permissions": { "type": "boolean" },
            "destructive_operations_require_approval": { "type": "boolean" },
            "production_deployment_requires_pipeline": { "type": "boolean" }
          }
        },
        "approval": {
          "type": "object",
          "description": "Named approvers for different approval categories.",
          "additionalProperties": false,
          "properties": {
            "architecture_approver": { "type": "string" },
            "issue_creation_approver": { "type": "string" },
            "pull_request_approver": { "type": "string" },
            "deployment_approver": { "type": "string" },
            "default_approver": { "type": "string" }
          }
        },
        "review": {
          "type": "object",
          "description": "Governance review scheduling settings.",
          "additionalProperties": false,
          "properties": {
            "default_interval_days": { "type": "integer", "minimum": 1 },
            "notify_days_before": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "work_management": {
      "type": "object",
      "description": "Work management provider configuration.",
      "required": ["provider"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "description": "Active work management provider. Use 'mock' for local/offline development without a live provider.",
          "enum": ["github-issues", "jira", "azure-devops", "mock", "none"]
        },
        "github_issues": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
          "owner": { "type": "string", "description": "GitHub org or user owning the target repo." },
          "repo": { "type": "string", "description": "Repository name." },
          "label_prefix": { "type": "string", "description": "Prefix applied to framework-managed labels (e.g. 'ais:')." },
          "milestone_prefix": { "type": "string", "description": "Prefix for framework-managed milestones (e.g. 'Sprint')." },
          "default_assignee": { "type": "string", "description": "Default GitHub username to assign framework-created issues." },
          "milestone": { "type": ["string", "integer", "null"], "description": "Default milestone (name or ID) for new issues." }
        }
        },
        "jira": {
          "type": "object",
          "description": "Jira provider configuration. STUB — config schema is defined; live API calls require Phase 6 implementation. Use mock provider for local development.",
          "additionalProperties": false,
          "properties": {
            "base_url": { "type": "string", "description": "Jira instance base URL (e.g. https://acme.atlassian.net)." },
            "project_key": { "type": "string", "description": "Jira project key (e.g. PAYMENTS)." },
            "issue_type": { "type": "string", "description": "Default Jira issue type for framework-created items (e.g. Story, Task, Bug).", "default": "Story" },
            "auth_secret": { "type": "string", "description": "Name of the secret containing the Jira API token — never the token value itself." }
          }
        },
        "azure_devops": {
          "type": "object",
          "description": "Azure DevOps provider configuration. STUB — config schema is defined; live API calls require Phase 6 implementation. Use mock provider for local development.",
          "additionalProperties": false,
          "properties": {
            "org": { "type": "string", "description": "Azure DevOps organization name (e.g. acme-corp)." },
            "project": { "type": "string", "description": "Azure DevOps project name." },
            "area_path": { "type": "string", "description": "Default area path for framework-created work items (e.g. MyProject\\Engineering)." },
            "organization": { "type": "string", "description": "Alias for org — accepted for backward compatibility." },
            "auth_secret": { "type": "string", "description": "Name of the secret containing the Azure DevOps PAT — never the token value itself." }
          }
        },
        "mock": {
          "type": "object",
          "description": "Mock provider configuration for local/offline development. Writes work items to a local YAML file rather than a live system.",
          "additionalProperties": false,
          "properties": {
            "output_file": { "type": "string", "description": "Path where mock work items are written (e.g. docs/mock-work-items.yaml).", "default": "docs/mock-work-items.yaml" }
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "description": "Agent catalog and default instruction references.",
      "required": ["catalog"],
      "additionalProperties": false,
      "properties": {
        "catalog": {
          "type": "string",
          "description": "Path to the agent catalog YAML."
        },
        "default_instructions": {
          "type": "string",
          "description": "Path to default instructions file loaded by all agents."
        }
      }
    },
    "experiments": {
      "type": "object",
      "description": "Experiment-driven validation loop settings.",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "directory": { "type": "string" },
        "metrics_collection": { "type": "boolean" },
        "metrics_backend": { "type": ["string", "null"], "enum": ["github-actions", "prometheus", null] },
        "max_concurrent_experiments": { "type": "integer", "minimum": 1 },
        "require_charter": { "type": "boolean" },
        "require_hypothesis": { "type": "boolean" },
        "min_duration_days": { "type": "integer", "minimum": 1 }
      }
    },
    "audit": {
      "type": "object",
      "description": "Audit trail settings.",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "directory": { "type": "string" },
        "retention_days": { "type": "integer", "minimum": 1 },
        "tamper_evident": { "type": "boolean" },
        "auditable_events": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "phase_gates": {
      "type": "object",
      "description": "Phase gate transition controls.",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "require_human_sign_off": { "type": "boolean" },
        "require_evidence": { "type": "boolean" },
        "allow_override": { "type": "boolean" },
        "override_approver": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "description": "Context discovery and loading settings.",
      "additionalProperties": false,
      "properties": {
        "input_docs_dir": { "type": "string" },
        "project_context_dir": { "type": "string" },
        "max_context_files": { "type": "integer", "minimum": 1 },
        "prefer_recent_artifacts": { "type": "boolean" }
      }
    },
    "finops": {
      "type": "object",
      "description": "Token budget and cost control settings.",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "token_budget_per_session": { "type": "integer", "minimum": 0 },
        "token_budget_hard_limit": { "type": "integer", "minimum": 0 },
        "model_budget_escalation_owner": { "type": "string" },
        "flag_redundant_context_loading": { "type": "boolean" },
        "flag_unbounded_retry_loops": { "type": "boolean" }
      }
    },
    "mcp": {
      "type": "object",
      "description": "Model Context Protocol (MCP) server configuration. Defines the MCP servers available to agents in this repository.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Master switch for MCP server integration. Set to false to disable all MCP server connections regardless of individual server settings.",
          "default": false
        },
        "servers": {
          "type": "array",
          "description": "List of MCP servers available to agents. Only servers with enabled=true are connected.",
          "items": {
            "type": "object",
            "required": ["name", "url"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique name for this MCP server (e.g. github, filesystem, jira)."
              },
              "url": {
                "type": "string",
                "description": "MCP server endpoint URL or local socket path."
              },
              "capabilities": {
                "type": "array",
                "description": "List of capability identifiers this server provides (e.g. read_file, create_issue, search_code).",
                "items": { "type": "string" }
              },
              "enabled": {
                "type": "boolean",
                "description": "Whether this specific server is active. Defaults to true when the parent mcp.enabled is true.",
                "default": true
              }
            }
          }
        }
      }
    },
    "assessment": {
      "type": "object",
      "description": "Brownfield discovery and initialization assessment settings.",
      "additionalProperties": false,
      "properties": {
        "target_repo": {
          "type": "string",
          "description": "Path or GitHub owner/repo of the repository being assessed. Defaults to the current repository if omitted."
        },
        "output_path": {
          "type": "string",
          "description": "Directory where assessment output files are written (readiness-assessment.yaml, gap-report.md, initialization-state.yaml).",
          "default": "docs/assessment/"
        },
        "auto_run_on_init": {
          "type": "boolean",
          "description": "Whether the brownfield assessment runs automatically when the framework is first initialized on a repository.",
          "default": true
        }
      }
    }
  }
}
